# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# Environment files (never commit real secrets/configs)
environments/.env.dev
environments/.env.staging
environments/.env.prod
.env

# Local DEV data stores
/data/chroma/
/local_dev.db

# Testing / tooling
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# IDE
.vscode/
.idea/

# Claude Code harness-internal state (not project source)
.claude/

# OS
.DS_Store
Thumbs.db

# Terraform
# .terraform.lock.hcl is intentionally NOT ignored - it's a dependency
# lockfile (like package-lock.json) and should be committed per root module.
**/.terraform/
*.tfstate
*.tfstate.*
*.tfplan
backend.hcl
crash.log
crash.*.log
infra/terraform/modules/lambda-tools/.build/
infra/terraform/modules/kb-ingestion-sync/.build/

