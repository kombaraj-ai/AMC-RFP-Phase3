# -----------------------------------------------------------------------------
# DEV environment configuration template.
# Copy this file to `.env.dev` (gitignored) and adjust values as needed.
# DEV runs 100% locally: Ollama for the LLM, SQLite for quant data, ChromaDB
# (persisted to disk) for qualitative RAG. Zero cloud cost, zero cloud creds.
# -----------------------------------------------------------------------------

ENVIRONMENT=dev

# --- Model provider (Ollama) -------------------------------------------------
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL_ID=qwen2.5:7b-instruct
# Low temperature for the compliance/routing agents keeps verdicts consistent
# and integration tests less flaky; the synthesizer uses a slightly higher one.
MODEL_TEMPERATURE_JUDGE=0.15
MODEL_TEMPERATURE_WORKER=0.2
MODEL_TEMPERATURE_SYNTHESIS=0.4

# --- Quantitative data store (SQLite) ---------------------------------------
SQLITE_PATH=local_dev.db

# --- Qualitative data store (ChromaDB, persistent on-disk) -------------------
CHROMA_PERSIST_DIR=data/chroma
CHROMA_COLLECTION_NAME=fund_manager_commentary

# --- Compliance self-correction loop -----------------------------------------
MAX_COMPLIANCE_ATTEMPTS=3
GRAPH_EXECUTION_TIMEOUT_SECONDS=300
GRAPH_MAX_NODE_EXECUTIONS=12

# --- API server ---------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
# Comma-separated. "*" is fine for pure-localhost DEV; restrict in STAGING/PROD.
CORS_ORIGINS=*

# --- Observability ------------------------------------------------------------
LOG_LEVEL=DEBUG
LOG_FORMAT=json
