# -----------------------------------------------------------------------------
# DEV environment configuration template.
# Copy this file to `.env.dev` (gitignored) and adjust values as needed.
# DEV runs 100% locally: Ollama for the LLM, SQLite for quant data, ChromaDB
# (persisted to disk) for qualitative RAG. Zero cloud cost, zero cloud creds.
# -----------------------------------------------------------------------------

ENVIRONMENT=dev

# --- Model provider selection -------------------------------------------------
# Which LLM actually generates responses this run - independent of ENVIRONMENT
# (STAGING/PROD always use Bedrock regardless of this setting; only DEV
# respects it):
#   ollama  (default) - 100% local, free, but can be slow (CPU-only inference).
#   bedrock            - AWS Bedrock: much faster/higher quality, but needs AWS
#                        credentials configured (e.g. `aws configure` or an
#                        SSO profile) and incurs real per-request cost, even
#                        from DEV. Useful when local Ollama generation is too
#                        slow for a given use case.
MODEL_PROVIDER=ollama

# --- Model provider (Ollama; used when MODEL_PROVIDER=ollama) ---------------
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL_ID=qwen2.5:7b-instruct

# --- Model provider (Bedrock; used when MODEL_PROVIDER=bedrock) -------------
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
AWS_REGION=us-east-1

# Low temperature for the compliance/routing agents keeps verdicts consistent
# and integration tests less flaky; the synthesizer uses a slightly higher one.
# Applies to whichever provider is active above.
MODEL_TEMPERATURE_JUDGE=0.15
MODEL_TEMPERATURE_WORKER=0.2
MODEL_TEMPERATURE_SYNTHESIS=0.4

# --- Quantitative data store (SQLite) ---------------------------------------
SQLITE_PATH=local_dev.db

# --- Qualitative data store (ChromaDB, persistent on-disk) -------------------
CHROMA_PERSIST_DIR=data/chroma
CHROMA_COLLECTION_NAME=fund_manager_commentary

# --- Compliance self-correction loop -----------------------------------------
MAX_COMPLIANCE_ATTEMPTS=3
COMPLIANCE_STRUCTURED_OUTPUT_MAX_ATTEMPTS=3
GRAPH_EXECUTION_TIMEOUT_SECONDS=300
GRAPH_MAX_NODE_EXECUTIONS=12

# --- API server ---------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
# Comma-separated. "*" is fine for pure-localhost DEV; restrict in STAGING/PROD.
CORS_ORIGINS=*

# --- Observability ------------------------------------------------------------
LOG_LEVEL=DEBUG
LOG_FORMAT=json
