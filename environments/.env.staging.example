# -----------------------------------------------------------------------------
# STAGING environment configuration template (placeholder - not built yet).
# Model provider swaps to Amazon Bedrock; data layers are expected to swap to
# Snowflake/Redshift and Amazon OpenSearch in a later phase. No code changes
# are required in agents/tools to make this swap - only config + the data
# layer implementation swap behind the same function signatures.
# -----------------------------------------------------------------------------

ENVIRONMENT=staging

# --- Model provider (Amazon Bedrock) -----------------------------------------
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
AWS_REGION=us-east-1
MODEL_TEMPERATURE_JUDGE=0.15
MODEL_TEMPERATURE_WORKER=0.2
MODEL_TEMPERATURE_SYNTHESIS=0.4

# --- Quantitative data store (placeholder: Snowflake/Redshift in a later phase)
SQLITE_PATH=local_dev.db

# --- Qualitative data store (placeholder: Amazon OpenSearch in a later phase) -
CHROMA_PERSIST_DIR=data/chroma
CHROMA_COLLECTION_NAME=fund_manager_commentary

MAX_COMPLIANCE_ATTEMPTS=3
GRAPH_EXECUTION_TIMEOUT_SECONDS=300
GRAPH_MAX_NODE_EXECUTIONS=12

API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=https://amc-portal-staging.internal

LOG_LEVEL=INFO
LOG_FORMAT=json
