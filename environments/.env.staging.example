# -----------------------------------------------------------------------------
# STAGING environment configuration template (placeholder - app-code not
# built yet, see below).
# Model provider is Amazon Bedrock. Phase 02 (infra/terraform/) provisions
# DynamoDB (quant metrics) and OpenSearch Serverless + Bedrock Knowledge
# Base (qualitative RAG) via Terraform, replacing SQLite/Chroma - this
# supersedes an earlier guess at Snowflake/Redshift. The actual
# DYNAMODB_TABLE_NAME/OPENSEARCH_COLLECTION_ENDPOINT/etc settings and the
# data-layer code swap (data/sqlite_store.py, data/chroma_store.py) are a
# separate, not-yet-started app-code follow-on task - see
# infra/terraform/README.md's "Settings mapping" section for the planned
# field names once that lands.
# -----------------------------------------------------------------------------

ENVIRONMENT=staging

# --- Model provider (Amazon Bedrock) -----------------------------------------
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
AWS_REGION=us-east-1
MODEL_TEMPERATURE_JUDGE=0.15
MODEL_TEMPERATURE_WORKER=0.2
MODEL_TEMPERATURE_SYNTHESIS=0.4

# --- Quantitative data store (placeholder: DynamoDB, see header note) -------
SQLITE_PATH=local_dev.db

# --- Qualitative data store (placeholder: OpenSearch Serverless, see header note) -
CHROMA_PERSIST_DIR=data/chroma
CHROMA_COLLECTION_NAME=fund_manager_commentary

MAX_COMPLIANCE_ATTEMPTS=3
GRAPH_EXECUTION_TIMEOUT_SECONDS=300
GRAPH_MAX_NODE_EXECUTIONS=12

API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=https://amc-portal-staging.internal

LOG_LEVEL=INFO
LOG_FORMAT=json
