# -----------------------------------------------------------------------------
# PROD environment configuration template (placeholder - app-code not built
# yet). Mirrors STAGING's provider choices (see that file's header note on
# Phase 02's DynamoDB/OpenSearch Serverless data layer) with production
# endpoints/creds sourced from a secrets manager (never a plain .env file)
# and stricter CORS.
# -----------------------------------------------------------------------------

ENVIRONMENT=prod

BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
AWS_REGION=us-east-1
MODEL_TEMPERATURE_JUDGE=0.1
MODEL_TEMPERATURE_WORKER=0.2
MODEL_TEMPERATURE_SYNTHESIS=0.3

SQLITE_PATH=local_dev.db
CHROMA_PERSIST_DIR=data/chroma
CHROMA_COLLECTION_NAME=fund_manager_commentary

MAX_COMPLIANCE_ATTEMPTS=3
GRAPH_EXECUTION_TIMEOUT_SECONDS=300
GRAPH_MAX_NODE_EXECUTIONS=12

API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=https://amc-portal.internal

LOG_LEVEL=WARNING
LOG_FORMAT=json
